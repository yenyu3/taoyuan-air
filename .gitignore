# Data files (keep structure, ignore large data files)
data/raw/**/*
data/processed/**/*
data/exports/**/*
!data/raw/**/.gitkeep
!data/processed/.gitkeep
!data/exports/.gitkeep
!data/README.md

# WindLidar - tracked in git
!data/raw/WindLidar/
!data/raw/WindLidar/*

# CWA stations - Taoyuan filtered (2025+), tracked in git
!data/raw/cwa-stations/
!data/raw/cwa-stations/*/
!data/raw/cwa-stations/**/*

# MOE stations - Taoyuan filtered (2025+), tracked in git
!data/raw/moe-stations/
!data/raw/moe-stations/*/
!data/raw/moe-stations/**/*

# TYDEP stations - tracked in git (single 25MB Excel, Taoyuan-only)
!data/raw/tydep-stations/
!data/raw/tydep-stations/**/*

# TEDS point - keep folder structure, ignore files inside
data/raw/teds-point/*
!data/raw/teds-point/
!data/raw/teds-point/*/
!data/raw/teds-point/.gitkeep

